<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Central de Atendimento - Design Atualizado</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* Reset e configurações básicas */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        :root {
            --primary: #0046B8;
            --secondary: #F6B125;
            --white: #FFFFFF;
            --light-gray: #F5F5F5;
            --dark-gray: #333333;
        }

        body {
            background: var(--light-gray);
            color: var(--dark-gray);
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* Layout principal assimétrico */
        .container {
            display: grid;
            grid-template-columns: 1.2fr 0.8fr;
            min-height: 100vh;
        }

        /* Painel esquerdo - Conteúdo principal */
        .main-panel {
            background: linear-gradient(135deg, var(--primary) 0%, #003399 80%);
            color: var(--white);
            padding: 3rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
            position: relative;
            overflow: hidden;
        }

        .main-panel::before {
            content: "";
            position: absolute;
            top: -50%;
            right: -20%;
            width: 600px;
            height: 600px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.05);
        }

        .main-panel::after {
            content: "";
            position: absolute;
            bottom: -30%;
            left: -10%;
            width: 400px;
            height: 400px;
            border-radius: 50%;
            background: rgba(141, 12, 12, 0.03);
        }

        .logo {
            display: flex;
            align-items: center;
            margin-bottom: 2rem;
            z-index: 1;
            position: relative;
        }

        .logo-icon {
            width: 60px;
            height: 60px;
            background: rgba(255, 255, 255, 0.15);
            border-radius: 16px;
            display: flex;
            justify-content: center;
            align-items: center;
            margin-right: 1rem;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }

        .logo-icon i {
            font-size: 1.8rem;
            color: var(--secondary);
        }

        .logo-text {
            font-size: 1.5rem;
            font-weight: 700;
        }

        .main-content {
            max-width: 700px;
            z-index: 1;
            position: relative;
        }

        .main-title {
            font-size: 3.5rem;
            font-weight: 800;
            line-height: 1.1;
            margin-bottom: 1.5rem;
        }

        .main-subtitle {
            font-size: 1.2rem;
            opacity: 0.9;
            margin-bottom: 2.5rem;
            line-height: 1.6;
        }

        .features {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
            margin-bottom: 3rem;
        }

        .feature {
            display: flex;
            align-items: flex-start;
        }

        .feature-icon {
            width: 40px;
            height: 40px;
            background: rgba(255, 255, 255, 0.15);
            border-radius: 10px;
            display: flex;
            justify-content: center;
            align-items: center;
            margin-right: 1rem;
            flex-shrink: 0;
        }

        .feature-icon i {
            color: var(--secondary);
        }

        .feature-text h3 {
            font-size: 1.1rem;
            margin-bottom: 0.3rem;
        }

        .feature-text p {
            font-size: 0.9rem;
            opacity: 0.8;
        }

        .cta-button {
            display: inline-flex;
            align-items: center;
            background: var(--secondary);
            color: var(--dark-gray);
            padding: 1rem 2rem;
            border-radius: 12px;
            font-weight: 600;
            text-decoration: none;
            transition: transform 0.3s, box-shadow 0.3s;
            box-shadow: 0 10px 20px rgba(246, 177, 37, 0.3);
        }

        .cta-button:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 25px rgba(246, 177, 37, 0.4);
        }

        .cta-button i {
            margin-left: 0.5rem;
        }

        /* Painel direito - Formulário e interação */
        .form-panel {
            padding: 3rem;
            display: flex;
            flex-direction: column;
            justify-content: center;
            background: var(--white);
            width: 100%;
        }

        .form-container {
            max-width: 450px;
            margin: 0 auto;
            width: 100%;
        }

        .form-tabs {
            display: flex;
            margin-bottom: 2rem;
            background: var(--light-gray);
            border-radius: 12px;
            padding: 5px;
        }

        .form-tab {
            flex: 1;
            text-align: center;
            padding: 0.8rem;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.3s;
            font-weight: 600;
            color: var(--dark-gray);
        }

        .form-tab.active {
            background: var(--white);
            color: var(--primary);
            box-shadow: 0 4px 10px rgba(0, 70, 184, 0.15);
        }

        .form-card {
            background: var(--white);
            border-radius: 20px;
            padding: 2.5rem;
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.08);
            border: 1px solid rgba(0, 0, 0, 0.03);
        }

        .form-title {
            font-size: 1.8rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
            color: var(--dark-gray);
        }

        .form-subtitle {
            color: var(--dark-gray);
            opacity: 0.7;
            margin-bottom: 2rem;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-label {
            display: block;
            margin-bottom: 0.5rem;
            font-weight: 600;
            color: var(--dark-gray);
        }

        .form-control {
            width: 100%;
            padding: 1rem;
            border: 1px solid #E2E8F0;
            border-radius: 10px;
            font-size: 1rem;
            transition: all 0.3s;
            background: var(--light-gray);
        }

        .form-control:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(0, 70, 184, 0.1);
            background: var(--white);
        }

        textarea.form-control {
            min-height: 120px;
            resize: vertical;
        }

        .btn {
            display: inline-block;
            width: 100%;
            padding: 1rem;
            background: var(--primary);
            color: var(--white);
            border: none;
            border-radius: 10px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
        }

        .btn:hover {
            background: #003399;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(0, 70, 184, 0.2);
        }

        .auth-options {
            margin-top: 2rem;
            text-align: center;
        }

        .divider {
            display: flex;
            align-items: center;
            margin: 1.5rem 0;
        }

        .divider::before, .divider::after {
            content: "";
            flex: 1;
            height: 1px;
            background: #E2E8F0;
        }

        .divider span {
            padding: 0 1rem;
            color: var(--dark-gray);
            opacity: 0.7;
            font-size: 0.9rem;
        }

        .btn-google {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            background: var(--white);
            color: var(--dark-gray);
            border: 1px solid #E2E8F0;
        }

        .btn-google:hover {
            background: var(--light-gray);
            border-color: #CBD5E0;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
        }

        .form-footer {
            text-align: center;
            margin-top: 1.5rem;
            color: var(--dark-gray);
            opacity: 0.7;
        }

        .form-footer a {
            color: var(--primary);
            text-decoration: none;
            font-weight: 600;
        }

        .form-footer a:hover {
            text-decoration: underline;
        }

        /* Elementos decorativos */
        .floating-shapes {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
        }

        .shape {
            position: absolute;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.05);
        }

        .shape-1 {
            width: 80px;
            height: 80px;
            top: 20%;
            right: 15%;
            animation: float 8s ease-in-out infinite;
        }

        .shape-2 {
            width: 120px;
            height: 120px;
            bottom: 15%;
            right: 25%;
            animation: float 10s ease-in-out infinite reverse;
        }

        .shape-3 {
            width: 60px;
            height: 60px;
            top: 60%;
            left: 10%;
            animation: float 7s ease-in-out infinite 1s;
        }

        @keyframes float {
            0%, 100% {
                transform: translateY(0) rotate(0deg);
            }
            50% {
                transform: translateY(-20px) rotate(10deg);
            }
        }

        /* Modal de Login */
        .modal {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.7);
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 1000;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s ease;
        }

        .modal.active {
            opacity: 1;
            visibility: visible;
        }

        .modal-content {
            background: var(--white);
            border-radius: 20px;
            width: 90%;
            max-width: 450px;
            padding: 2.5rem;
            color: var(--dark-gray);
            position: relative;
            transform: translateY(20px);
            transition: transform 0.3s ease;
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.2);
        }

        .modal.active .modal-content {
            transform: translateY(0);
        }

        .close-modal {
            position: absolute;
            top: 1.5rem;
            right: 1.5rem;
            font-size: 1.5rem;
            cursor: pointer;
            color: var(--dark-gray);
            opacity: 0.7;
        }

        .close-modal:hover {
            opacity: 1;
        }

        .modal-title {
            font-size: 1.8rem;
            margin-bottom: 0.5rem;
            color: var(--dark-gray);
            text-align: center;
        }

        .modal-subtitle {
            color: var(--dark-gray);
            opacity: 0.7;
            margin-bottom: 2rem;
            text-align: center;
        }

        .remember-forgot {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
        }

        .remember {
            display: flex;
            align-items: center;
        }

        .remember input {
            margin-right: 0.5rem;
        }

        .forgot-password {
            color: var(--primary);
            text-decoration: none;
            font-size: 0.9rem;
        }

        .forgot-password:hover {
            text-decoration: underline;
        }

        /* Mensagens de feedback */
        .alert {
            padding: 1rem;
            border-radius: 10px;
            margin-bottom: 1.5rem;
            font-size: 0.9rem;
        }

        .alert-success {
            background: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }

        .alert-error {
            background: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }

        /* Responsividade */
        @media (max-width: 1024px) {
            .container {
                grid-template-columns: 1fr;
            }
            
            .main-panel {
                padding: 2rem;
            }
            
            .form-panel {
                padding: 2rem;
            }
        }

        @media (max-width: 768px) {
            .main-title {
                font-size: 2.5rem;
            }
            
            .features {
                grid-template-columns: 1fr;
            }
            
            .form-card, .modal-content {
                padding: 2rem;
            }
        }

        @media (max-width: 480px) {
            .main-panel, .form-panel {
                padding: 1.5rem;
            }
            
            .main-title {
                font-size: 2rem;
            }
            
            .form-card, .modal-content {
                padding: 1.5rem;
            }
            
            .remember-forgot {
                flex-direction: column;
                align-items: flex-start;
                gap: 0.5rem;
            }
        }

        /* Animações */
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .animate-fadeInUp {
            animation: fadeInUp 0.8s ease-out forwards;
        }

        .delay-1 {
            animation-delay: 0.2s;
            opacity: 0;
        }

        .delay-2 {
            animation-delay: 0.4s;
            opacity: 0;
        }

        .delay-3 {
            animation-delay: 0.6s;
            opacity: 0;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Painel Esquerdo - Conteúdo Principal -->
        <div class="main-panel" >
            <div class="floating-shapes">
                <div class="shape shape-1"></div>
                <div class="shape shape-2"></div>
                <div class="shape shape-3"></div>
            </div>
            
            <div class="logo animate-fadeInUp">
                <div class="logo-icon">
                    <i class="fas fa-headset"></i>
                </div>
                <div class="logo-text">Suporte Pro</div>
            </div>
            
            <div class="main-content">
                <h1 class="main-title animate-fadeInUp delay-1">Sua Voz é <span style="color: var(--secondary)">Importante</span> Para Nós</h1>
                <p class="main-subtitle animate-fadeInUp delay-1">Conectamos você com as soluções que precisa. Nossa equipe está pronta para transformar suas experiências em melhorias contínuas.</p>
                
                <div class="features">
                    <div class="feature animate-fadeInUp delay-2">
                        <div class="feature-icon">
                            <i class="fas fa-bolt"></i>
                        </div>
                        <div class="feature-text">
                            <h3>Resposta Rápida</h3>
                            <p>Atendimento ágil em menos de 24h</p>
                        </div>
                    </div>
                    <div class="feature animate-fadeInUp delay-2">
                        <div class="feature-icon">
                            <i class="fas fa-shield-alt"></i>
                        </div>
                        <div class="feature-text">
                            <h3>Privacidade Garantida</h3>
                            <p>Seus dados estão sempre protegidos</p>
                        </div>
                    </div>
                    <div class="feature animate-fadeInUp delay-3">
                        <div class="feature-icon">
                            <i class="fas fa-chart-line"></i>
                        </div>
                        <div class="feature-text">
                            <h3>Soluções Eficazes</h3>
                            <p>Resultados que fazem a diferença</p>
                        </div>
                    </div>
                    <div class="feature animate-fadeInUp delay-3">
                        <div class="feature-icon">
                            <i class="fas fa-users"></i>
                        </div>
                        <div class="feature-text">
                            <h3>Atendimento Humanizado</h3>
                            <p>Profissionais dedicados ao seu caso</p>
                        </div>
                    </div>
                </div>
                
                <a href="#" class="cta-button animate-fadeInUp delay-3" onclick="openLoginModal()">
                    Minha conta <i class="fas fa-arrow-right"></i>
                </a>
            </div>
        </div>
        
        <!-- Painel Direito - Formulário e Interação -->
        <div class="form-panel" >
            <div class="form-container">
                <div class="form-card">
                    <!-- Área para mensagens de feedback -->
                    <div id="feedback-message" style="display: none;"></div>
                    
                    <h2 class="form-title">Envie sua Reclamação ou Sugestão</h2>
                    <p class="form-subtitle">Descreva o problema encontrado para que possamos resolvê-lo</p>
                    
                    <form id="main-form" action="/solicitacoes/nova" method="post">
                        <div class="form-group">
                            <label for="name" class="form-label">Nome Completo *</label>
                            <input type="text" name="cliente_nome" id="name" class="form-control" required>
                        </div>
                        
                        <div class="form-group">
                            <label for="email" class="form-label">E-mail *</label>
                            <input type="email" name="cliente_email" id="email" class="form-control" required>
                        </div>
                        
                        <div class="form-group">
                            <label for="subject" class="form-label">Assunto *</label>
                            <input type="text" name="titulo" id="subject" class="form-control" required>
                        </div>
                        
                        <div class="form-group">
                            <label for="category" class="form-label">Categoria *</label>
                            <select id="category" name="categoria" class="form-control" required>
                                <option value="">Selecione uma categoria</option>
                                <option value="faturacao">Problemas com Faturação</option>
                                <option value="servico">Mau Atendimento</option>
                                <option value="tecnico">Problemas Técnicos</option>
                                <option value="outro">Outro</option>
                            </select>
                        </div>
                        
                        <div class="form-group">
                            <label for="description" class="form-label">Descrição Detalhada *</label>
                            <textarea id="description" name="descricao" class="form-control" required placeholder="Descreva o problema em detalhes..."></textarea>
                        </div>
                        
                        <button type="submit" class="btn" id="submit-btn">Enviar Mensagem</button>
                    </form>
                    
                    <div class="auth-options">
                        <div class="divider">
                            <span>ou entre com sua conta</span>
                        </div>
                        
                        <button class="btn btn-google" onclick="loginWithGoogle()">
                            <i class="fab fa-google"></i> Continuar com Google
                        </button>
                        
                        <div class="form-footer">
                            Já tem uma conta? <a href="#" onclick="openLoginModal()">Faça login</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal de Login -->
    <div class="modal" id="login-modal">
        <div class="modal-content">
            <span class="close-modal" onclick="closeLoginModal()">&times;</span>
            <h2 class="modal-title">Entrar na Conta</h2>
            <p class="modal-subtitle">Acesse sua conta para acompanhar suas solicitações</p>
            
            <form id="login-form" onsubmit="handleLogin(event)">
                <div class="form-group">
                    <label for="login-email" class="form-label">E-mail</label>
                    <input type="email" id="login-email" class="form-control" required placeholder="informe o seu email">
                </div>
                
                <div class="form-group">
                    <label for="login-password" class="form-label">Senha</label>
                    <input type="password" id="login-password" class="form-control" required placeholder="informe a sua senha">
                </div>
                
                <div class="remember-forgot">
                    <div class="remember">
                        <input type="checkbox" id="remember">
                        <label for="remember">Lembrar-me</label>
                    </div>
                    <a href="#" class="forgot-password">Esqueceu a senha?</a>
                </div>
                
                <button type="submit" class="btn">Entrar</button>
            </form>
            
            <div class="auth-options">
                <div class="divider">
                    <span>ou entre com</span>
                </div>
                
                <button class="btn btn-google" onclick="loginWithGoogle()">
                    <i class="fab fa-google"></i> Conta do Google
                </button>
                
                <div class="form-footer">
                    Não tem uma conta? <a href="#" onclick="openRegisterModal()">Cadastre-se</a>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Variáveis globais
        let currentTab = 'reclamacao';
        const loginModal = document.getElementById('login-modal');
        
        // Função para enviar o formulário com AJAX (evita recarregar a página)
        async function submitFormAjax(event) {
            event.preventDefault();
            
            const form = document.getElementById('main-form');
            const submitBtn = document.getElementById('submit-btn');
            const feedbackDiv = document.getElementById('feedback-message');
            
            // Desabilitar botão durante o envio
            submitBtn.disabled = true;
            submitBtn.textContent = 'Enviando...';
            
            // Coletar dados do formulário
            const formData = new FormData(form);
            const formObject = {};
            formData.forEach((value, key) => {
                formObject[key] = value;
            });
            
            try {
                const response = await fetch('/solicitacoes/nova', {
                    method: 'POST',
                    headers: { 
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(formObject)
                });
                
                const result = await response.json();
                
                if (response.ok && result.success) {
                    // Mostrar mensagem de sucesso
                    feedbackDiv.style.display = 'block';
                    feedbackDiv.className = 'alert alert-success';
                    feedbackDiv.innerHTML = '✅ Solicitação enviada com sucesso! Em breve entraremos em contato.';
                    
                    // Limpar formulário
                    form.reset();
                    
                    // Esconder mensagem após 5 segundos
                    setTimeout(() => {
                        feedbackDiv.style.display = 'none';
                    }, 5000);
                } else {
                    // Mostrar mensagem de erro
                    feedbackDiv.style.display = 'block';
                    feedbackDiv.className = 'alert alert-error';
                    feedbackDiv.innerHTML = '❌ Erro ao enviar solicitação: ' + (result.error || 'Tente novamente mais tarde.');
                    
                    setTimeout(() => {
                        feedbackDiv.style.display = 'none';
                    }, 5000);
                }
            } catch (error) {
                console.error('Erro:', error);
                feedbackDiv.style.display = 'block';
                feedbackDiv.className = 'alert alert-error';
                feedbackDiv.innerHTML = '❌ Erro de conexão. Verifique sua internet e tente novamente.';
                
                setTimeout(() => {
                    feedbackDiv.style.display = 'none';
                }, 5000);
            } finally {
                // Reabilitar botão
                submitBtn.disabled = false;
                submitBtn.textContent = 'Enviar Mensagem';
            }
        }
        
        // Função para login com Google (simulada)
        function loginWithGoogle() {
            alert('Login com Google realizado com sucesso! Em uma aplicação real, isso integraria com a API do Google.');
            closeLoginModal();
        }
        
        // Função para abrir modal de login
        function openLoginModal() {
            loginModal.classList.add('active');
        }
        
        // Função para fechar modal de login
        function closeLoginModal() {
            loginModal.classList.remove('active');
        }
        
        // Função para processar login
        async function handleLogin(event) {
            event.preventDefault();
            
            const email = document.getElementById('login-email').value;
            const senha = document.getElementById('login-password').value;
            
            try {
                const response = await fetch('/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, senha })
                });
                
                const data = await response.json();
                
                if (data.tipo === "sucesso") {
                    window.location.href = '/dashboard';
                } else {
                    alert('Email ou senha inválidos. Tente novamente.');
                }
            } catch (error) {
                console.error('Erro no login:', error);
                alert('Erro ao conectar ao servidor. Tente novamente.');
            }
        }
        
        // Função para abrir modal de registro (simulada)
        function openRegisterModal() {
            alert('Modal de registro aberto! Em uma aplicação real, isso abriria um formulário de cadastro.');
            closeLoginModal();
        }
        
        // Fechar modal ao clicar fora dele
        window.addEventListener('click', function(event) {
            if (event.target === loginModal) {
                closeLoginModal();
            }
        });
        
        // Inicialização quando a página carrega
        document.addEventListener('DOMContentLoaded', function() {
            // Adicionar evento de submit ao formulário
            const form = document.getElementById('main-form');
            if (form) {
                form.addEventListener('submit', submitFormAjax);
            }
            
            // Adicionar animação de entrada para elementos
            const animatedElements = document.querySelectorAll('.animate-fadeInUp');
            animatedElements.forEach(el => {
                if (el.classList.contains('delay-1') || 
                    el.classList.contains('delay-2') || 
                    el.classList.contains('delay-3')) {
                    // As classes de delay já estão aplicadas no HTML
                }
            });
        });
    </script>
</body>
</html>