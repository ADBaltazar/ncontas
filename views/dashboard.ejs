        async function deleteSolicitacao() { /* Implementado anteriormente */ }
        async function updateStatus(id, status) { /* Implementado anteriormente */ }

        // Configurar botão de exclusão
        document.getElementById('confirm-delete-btn').onclick = async () => {
            if (deleteType === 'usuario') {
                try {
                    const response = await fetch(`/api/usuarios/${deleteId}`, { method: 'DELETE' });
                    const result = await response.json();
                    if (result.success) {
                        showToast('Usuário excluído com sucesso!', 'success');
                        closeConfirmDeleteModal();
                        loadUsuarios();
                    }
                } catch (error) {
                    showToast('Erro ao excluir usuário', 'error');
                }
            } else {
                await deleteSolicitacao();
            }
        };

        // Event listeners para relatório
        document.getElementById('relatorio-tipo').addEventListener('change', loadRelatorio);
        document.getElementById('relatorio-data-inicio').addEventListener('change', loadRelatorio);
        document.getElementById('relatorio-data-fim').addEventListener('change', loadRelatorio);
        document.getElementById('relatorio-status').addEventListener('change', loadRelatorio);

        // Inicialização
        document.addEventListener('DOMContentLoaded', () => {
            const rows = document.querySelectorAll('#table-body tr');
            document.getElementById('total-exibidos').innerText = rows.length;
            document.getElementById('total-registros').innerText = rows.length;
            updatePagination();
        });
    </script>
