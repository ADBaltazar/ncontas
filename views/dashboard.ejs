    <script>
        // Variáveis globais
        let currentPage = 1;
        const rowsPerPage = 10;
        let deleteId = null;
        let deleteType = null;
        let statusChart, prioridadeChart, mensalChart, categoriaChart;

        // ==================== NAVEGAÇÃO ====================
        function showSection(sectionId) {
            document.querySelectorAll('.section').forEach(section => {
                section.classList.remove('active');
            });
            document.getElementById(`${sectionId}-section`).classList.add('active');
            
            document.querySelectorAll('.nav-link').forEach(link => {
                link.classList.remove('active');
            });
            event.target.closest('.nav-link').classList.add('active');

            if (sectionId === 'estatisticas') {
                loadCharts();
            } else if (sectionId === 'relatorios') {
                loadRelatorio();
            } else if (sectionId === 'usuarios') {
                loadUsuarios();
            }
        }

        // ==================== FILTROS ====================
        function applyFilters() {
            const status = document.getElementById('filter-status').value;
            const prioridade = document.getElementById('filter-prioridade').value;
            const cliente = document.getElementById('filter-cliente').value.toLowerCase();
            
            const rows = document.querySelectorAll('#table-body tr');
            let visibleCount = 0;
            
            rows.forEach(row => {
                let show = true;
                if (status !== 'all' && row.dataset.status !== status) show = false;
                if (prioridade !== 'all' && row.dataset.prioridade !== prioridade) show = false;
                if (cliente && !row.dataset.cliente.includes(cliente)) show = false;
                row.style.display = show ? '' : 'none';
                if (show) visibleCount++;
            });
            
            document.getElementById('total-exibidos').innerText = visibleCount;
            document.getElementById('total-registros').innerText = rows.length;
            currentPage = 1;
            updatePagination();
        }

        function updatePagination() {
            const rows = Array.from(document.querySelectorAll('#table-body tr')).filter(row => row.style.display !== 'none');
            const totalPages = Math.ceil(rows.length / rowsPerPage);
            const paginationDiv = document.getElementById('pagination');
            
            if (totalPages <= 1) {
                paginationDiv.innerHTML = '';
                return;
            }
            
            let paginationHtml = '';
            for (let i = 1; i <= totalPages; i++) {
                paginationHtml += `<button class="page-btn ${i === currentPage ? 'active' : ''}" onclick="goToPage(${i})">${i}</button>`;
            }
            paginationDiv.innerHTML = paginationHtml;
            showPage(currentPage);
        }

        function showPage(page) {
            const rows = Array.from(document.querySelectorAll('#table-body tr')).filter(row => row.style.display !== 'none');
            const start = (page - 1) * rowsPerPage;
            const end = start + rowsPerPage;
            
            rows.forEach((row, index) => {
                row.style.display = (index >= start && index < end) ? '' : 'none';
            });
        }

        function goToPage(page) {
            currentPage = page;
            showPage(page);
            updatePagination();
        }

        // ==================== GRÁFICOS ====================
        async function loadCharts() {
            try {
                const response = await fetch('/api/estatisticas');
                const data = await response.json();
                
                if (statusChart) statusChart.destroy();
                if (prioridadeChart) prioridadeChart.destroy();
                if (mensalChart) mensalChart.destroy();
                if (categoriaChart) categoriaChart.destroy();

                statusChart = new Chart(document.getElementById('statusChart'), {
                    type: 'pie',
                    data: {
                        labels: ['Pendente', 'Em Andamento', 'Resolvido', 'Cancelado'],
                        datasets: [{
                            data: [data.pendente, data.em_andamento, data.resolvido, data.cancelado],
                            backgroundColor: ['#F6B125', '#0046B8', '#28a745', '#dc3545']
                        }]
                    }
                });

                prioridadeChart = new Chart(document.getElementById('prioridadeChart'), {
                    type: 'pie',
                    data: {
                        labels: ['Baixa', 'Média', 'Alta', 'Urgente'],
                        datasets: [{
                            data: [data.baixa, data.media, data.alta, data.urgente],
                            backgroundColor: ['#28a745', '#F6B125', '#dc3545', '#dc3545']
                        }]
                    }
                });

                mensalChart = new Chart(document.getElementById('mensalChart'), {
                    type: 'line',
                    data: {
                        labels: data.meses,
                        datasets: [{
                            label: 'Solicitações',
                            data: data.quantidades,
                            borderColor: '#0046B8',
                            backgroundColor: 'rgba(0, 70, 184, 0.1)',
                            fill: true
                        }]
                    }
                });

                categoriaChart = new Chart(document.getElementById('categoriaChart'), {
                    type: 'bar',
                    data: {
                        labels: ['Faturação', 'Serviço', 'Técnico', 'Outro'],
                        datasets: [{
                            label: 'Quantidade',
                            data: [data.faturacao, data.servico, data.tecnico, data.outro],
                            backgroundColor: '#0046B8'
                        }]
                    }
                });
            } catch (error) {
                console.error('Erro ao carregar gráficos:', error);
            }
        }

        // ==================== RELATÓRIOS ====================
        async function loadRelatorio() {
            const tipo = document.getElementById('relatorio-tipo').value;
            const dataInicio = document.getElementById('relatorio-data-inicio').value;
            const dataFim = document.getElementById('relatorio-data-fim').value;
            const status = document.getElementById('relatorio-status').value;
            
            try {
                const response = await fetch(`/api/relatorio?tipo=${tipo}&inicio=${dataInicio}&fim=${dataFim}&status=${status}`);
                const data = await response.json();
                
                const tbody = document.getElementById('relatorio-body');
                tbody.innerHTML = data.map(item => `
                    <tr>
                        <td>${item.codigo}</td>
                        <td>${item.cliente_nome}</td>
                        <td>${item.titulo}</td>
                        <td><span class="badge badge-${item.prioridade}">${item.prioridade}</span></td>
                        <td><span class="badge badge-${item.status}">${item.status}</span></td>
                        <td>${new Date(item.data_abertura).toLocaleDateString('pt-BR')}</td>
                        <td>${item.usuario_responsavel || '-'}</td>
                    </tr>
                `).join('');
                
                document.getElementById('relatorio-info').innerHTML = `Total: ${data.length} registros`;
            } catch (error) {
                console.error('Erro ao carregar relatório:', error);
            }
        }

        function exportRelatorioExcel() {
            const table = document.getElementById('relatorio-table');
            const ws = XLSX.utils.table_to_sheet(table);
            const wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, ws, 'Relatorio');
            XLSX.writeFile(wb, `relatorio_${new Date().toISOString().split('T')[0]}.xlsx`);
            showToast('Relatório exportado com sucesso!', 'success');
        }

        function exportRelatorioPDF() {
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF({ orientation: 'landscape' });
            
            doc.text('Relatório de Solicitações', 14, 15);
            doc.text(`Data: ${new Date().toLocaleString('pt-BR')}`, 14, 25);
            
            doc.autoTable({ html: '#relatorio-table', startY: 35 });
            doc.save(`relatorio_${new Date().toISOString().split('T')[0]}.pdf`);
            showToast('Relatório exportado com sucesso!', 'success');
        }

        // ==================== GESTÃO DE UTILIZADORES ====================
        async function loadUsuarios() {
            try {
                const response = await fetch('/api/usuarios');
                const usuarios = await response.json();
                
                const tbody = document.getElementById('usuarios-body');
                tbody.innerHTML = usuarios.map(usuario => `
                    <tr>
                        <td>${usuario.nome}</td>
                        <td>${usuario.email}</td>
                        <td><span class="badge badge-${usuario.tipo}">${usuario.tipo}</span></td>
                        <td>
                            <span class="user-status ${usuario.ativo ? 'user-status-active' : 'user-status-inactive'}"></span>
                            ${usuario.ativo ? 'Ativo' : 'Inativo'}
                        </td>
                        <td>${new Date(usuario.createdAt).toLocaleDateString('pt-BR')}</td>
                        <td>
                            <div class="action-buttons">
                                <button class="action-btn btn-edit" onclick="openEditarUsuarioModal('${usuario._id}')">
                                    <i class="fas fa-edit"></i> Editar
                                </button>
                                <button class="action-btn btn-delete" onclick="confirmDeleteUsuario('${usuario._id}', '${usuario.nome}')">
                                    <i class="fas fa-trash"></i> Excluir
                                </button>
                            </div>
                        </td>
                    </tr>
                `).join('');
            } catch (error) {
                console.error('Erro ao carregar usuários:', error);
            }
        }

        function openNovoUsuarioModal() {
            document.getElementById('novo-usuario-modal').classList.add('active');
        }

        function closeNovoUsuarioModal() {
            document.getElementById('novo-usuario-modal').classList.remove('active');
            document.getElementById('novo-usuario-form').reset();
        }

        async function submitNovoUsuario(event) {
            event.preventDefault();
            
            const formData = {
                nome: document.getElementById('novo-nome').value,
                email: document.getElementById('novo-email').value,
                senha: document.getElementById('novo-senha').value,
                tipo: document.getElementById('novo-tipo').value
            };
            
            try {
                const response = await fetch('/api/usuarios', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(formData)
                });
                
                const result = await response.json();
                if (result.success) {
                    showToast('Usuário criado com sucesso!', 'success');
                    closeNovoUsuarioModal();
                    loadUsuarios();
                } else {
                    showToast('Erro ao criar usuário', 'error');
                }
            } catch (error) {
                showToast('Erro ao criar usuário', 'error');
            }
        }

        async function openEditarUsuarioModal(id) {
            try {
                const response = await fetch(`/api/usuarios/${id}`);
                const usuario = await response.json();
                
                document.getElementById('edit-usuario-id').value = usuario._id;
                document.getElementById('edit-usuario-nome').value = usuario.nome;
                document.getElementById('edit-usuario-email').value = usuario.email;
                document.getElementById('edit-usuario-tipo').value = usuario.tipo;
                document.getElementById('edit-usuario-status').value = usuario.ativo;
                
                document.getElementById('editar-usuario-modal').classList.add('active');
            } catch (error) {
                showToast('Erro ao carregar usuário', 'error');
            }
        }

        function closeEditarUsuarioModal() {
            document.getElementById('editar-usuario-modal').classList.remove('active');
            document.getElementById('editar-usuario-form').reset();
        }

        async function submitEditarUsuario(event) {
            event.preventDefault();
            
            const id = document.getElementById('edit-usuario-id').value;
            const formData = {
                nome: document.getElementById('edit-usuario-nome').value,
                email: document.getElementById('edit-usuario-email').value,
                tipo: document.getElementById('edit-usuario-tipo').value,
                ativo: document.getElementById('edit-usuario-status').value === 'true'
            };
            
            const senha = document.getElementById('edit-usuario-senha').value;
            if (senha) formData.senha = senha;
            
            try {
                const response = await fetch(`/api/usuarios/${id}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(formData)
                });
                
                const result = await response.json();
                if (result.success) {
                    showToast('Usuário atualizado com sucesso!', 'success');
                    closeEditarUsuarioModal();
                    loadUsuarios();
                } else {
                    showToast('Erro ao atualizar usuário', 'error');
                }
            } catch (error) {
                showToast('Erro ao atualizar usuário', 'error');
            }
        }

        function confirmDeleteUsuario(id, nome) {
            deleteId = id;
            deleteType = 'usuario';
            document.getElementById('delete-message').innerHTML = `Tem certeza que deseja excluir o usuário <strong>${nome}</strong>?`;
            document.getElementById('confirm-delete-modal').classList.add('active');
        }

        // ==================== FUNÇÕES EXISTENTES ====================
        function showToast(message, type) {
            const toast = document.createElement('div');
            toast.className = `toast-notification toast-${type}`;
            toast.innerHTML = message;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);
        }

