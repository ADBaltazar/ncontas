                    <select name="Cliente" id="" class="form-control" >
                        <% solicitacoesRecentes.forEach(solicitacao => { %>
                            <option value="<%= solicitacao.codigo %>"><%= solicitacao.cliente_nome %> </option>
                        <% }) %>
                    </select>
                </div>
                
                <div class="form-group">
                    <label for="schedule-date" class="form-label">Data do Atendimento</label>
                    <input type="date" name="data" id="schedule-date" class="form-control" required>
                </div>
                
                <div class="form-group">
                    <label for="schedule-time" class="form-label">Horário</label>
                    <input type="time" name="Hora" id="schedule-time" class="form-control" required>
                </div>
                
                <div class="form-group">
                    <label for="employee" class="form-label">Funcionário Responsável</label>
                    <select name="Responsavel" id="employee" class="form-control" required>
                        <option value="">Selecione um funcionário</option>
                        <option value="joao">João Silva - Técnico Sênior</option>
                        <option value="maria">Maria Santos - Especialista Fiscal</option>
                        <option value="carlos">Carlos Oliveira - Consultor</option>
                        <option value="ana">Ana Costa - Atendimento</option>
                    </select>
                </div>
                
                <div class="form-group">
                    <label for="notes" class="form-label">Observações</label>
                    <textarea id="notes" name="Observacao" class="form-control" rows="4" placeholder="Adicione observações sobre o atendimento..."></textarea>
                </div>
                
                <div class="filters-actions">
                    <button type="button" class="btn btn-secondary" onclick="closeScheduleModal()">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Confirmar Agendamento</button>
                </div>
            </form>
        </div>
    </div>

